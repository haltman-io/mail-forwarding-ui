# Comma-separated list of domains handled by the mail-forwarding-core service.
NEXT_PUBLIC_DOMAINS=alias1.example.com,alias2.example.com
# Enable floating debug toolbar in development mode (true/false).
# Only works with `npm run dev`; ignored in production builds.
NEXT_PUBLIC_DEBUG_UI=false
# Enable or disable the dashboard (sign in, sign up, forgot/reset password).
# When false, auth forms are visually disabled and non-interactive.
NEXT_DASHBOARD_ENABLED=true